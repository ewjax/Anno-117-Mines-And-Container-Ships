    <!--========================
        CONSTRUCTION MENU — Insert tab after Armor Chain in Military Construction menu
        ======================== -->
    <ModOp Add = "@41338/ConstructionCategory/BuildingList">
        <Item>
            <Building>2000101330</Building>
        </Item>
    </ModOp>


    <!--========================
        UNHIDE at 75 smiths — Hook into vanilla trigger 8070
        New games: makes tab appear grayed out / locked at 75 Smiths, unlocks it at 150 Smiths.
        ======================== -->

    <ModOp Add="@8070/Trigger/TriggerActions/Item/TriggerAction/Values/ActionUnlockAsset/UnhideAssets">
        <Item>
            <Asset>2000101330</Asset>
        </Item>
    </ModOp>

    <!--========================
        UNLOCK at 125 Smiths — Hook into vanilla trigger
        New games: makes tab fully unlocked and buildable at 125 Smiths, or if player already has 125 Smiths on load
        ======================== -->

    <ModOp Add="@8071/Trigger/TriggerActions/Item/TriggerAction/Values/ActionUnlockAsset/UnlockAssets">
        <Item>
            <Asset>2000101330</Asset>
        </Item>
        <Item>
            <Asset>2000101300</Asset>
        </Item>
        <Item>
            <Asset>2000101321</Asset>
        </Item>
    </ModOp>

    <!--========================
        TRIGGER — Existing save compatibility at 200 Plebeians
        Fires on load if already between 200-300 Plebeians.
        Unhides the tab so it shows locked/grayed in the construction menu.
        ======================== -->
    <Asset>
        <Template>TriggerIntermediateLevel</Template>
        <Values>
        <Standard>
            <GUID>2000101331</GUID>
        </Standard>
        <Trigger>
            <TriggerCondition>
            <Template>ConditionPlayerCounter</Template>
            <Values>
                <Condition />
                <ConditionPlayerCounter>
                <PlayerCounter>PopulationByLevel</PlayerCounter>
                <Context>1501</Context>
                <CounterAmount>75</CounterAmount>
                </ConditionPlayerCounter>
                <ConditionLocationProps />
                <ConditionCounterProps />
                <ConditionPropsComparable />
            </Values>
            </TriggerCondition>
            <TriggerActions>
            <Item>
                <TriggerAction>
                <Template>ActionUnlockAsset</Template>
                <Values>
                    <Action />
                    <ActionUnlockAsset>
                    <UnhideAssets>
                        <Item><Asset>2000101330</Asset></Item>
                    </UnhideAssets>
                    </ActionUnlockAsset>
                </Values>
                </TriggerAction>
            </Item>
            </TriggerActions>
        </Trigger>
        <TriggerSetup />
        <TrackingData />
        </Values>
    </Asset>

    <!--========================
        TRIGGER — Existing save compatibility at 300 Plebeians
        Fires on load if 300 Plebeians already reached.
        ======================== -->
    <Asset>
        <Template>TriggerIntermediateLevel</Template>
        <Values>
        <Standard>
            <GUID>2000101332</GUID>
        </Standard>
        <Trigger>
            <TriggerCondition>
