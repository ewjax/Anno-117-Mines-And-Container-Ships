                <Template>ActionUnlockAsset</Template>
                <Values>
                    <Action />
                    <ActionUnlockAsset>
                    <UnlockAssets>
                        <Item><Asset>2000101330</Asset></Item>
                        <Item><Asset>2000101300</Asset></Item>
                        <Item><Asset>2000101321</Asset></Item>
                    </UnlockAssets>
                    </ActionUnlockAsset>
                </Values>
                </TriggerAction>
            </Item>
            </TriggerActions>
        </Trigger>
        <TriggerSetup />
        <TrackingData />
        </Values>
    </Asset>

