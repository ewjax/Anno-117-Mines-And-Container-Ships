    <!--========================
        TRIGGER — Existing save compatibility at 200 Plebeians
        Fires on load if already between 200-300 Plebeians.
        Unhides the tab so it shows locked/grayed in the construction menu.
        ======================== -->
    <Asset>
        <Template>TriggerIntermediateLevel</Template>
        <Values>
        <Standard>
            <GUID>2000101311</GUID>
        </Standard>
        <Trigger>
            <TriggerCondition>
            <Template>ConditionPlayerCounter</Template>
            <Values>
                <Condition />
                <ConditionPlayerCounter>
                <PlayerCounter>PopulationByLevel</PlayerCounter>
                <Context>1496</Context>
                <CounterAmount>200</CounterAmount>
                </ConditionPlayerCounter>
                <ConditionLocationProps />
                <ConditionCounterProps />
                <ConditionPropsComparable />
            </Values>
            </TriggerCondition>
            <TriggerActions>
            <Item>
                <TriggerAction>
                <Template>ActionUnlockAsset</Template>
                <Values>
                    <Action />
                    <ActionUnlockAsset>
                    <UnhideAssets>
                        <Item><Asset>2000101310</Asset></Item>
                    </UnhideAssets>
                    </ActionUnlockAsset>
                </Values>
                </TriggerAction>
            </Item>
            </TriggerActions>
        </Trigger>
        <TriggerSetup />
        <TrackingData />
        </Values>
    </Asset>

